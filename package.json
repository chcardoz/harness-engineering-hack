{
  "name": "yougrep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @yougrep/web dev",
    "build": "pnpm --filter @yougrep/web build",
    "start": "pnpm --filter @yougrep/web start",
    "worker": "pnpm --filter @yougrep/worker dev",
    "db:reset": "pnpm --filter @yougrep/db reset",
    "db:seed": "pnpm --filter @yougrep/db seed",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
