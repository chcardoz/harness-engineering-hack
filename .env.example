# Yougrep — local environment template.
#
# Copy this to `.env` (gitignored) and paste your keys. Every process — the
# Next.js web app, the worker, and the tsx db scripts — loads this one root
# file via packages/config. Real shell env vars and the Render dashboard always
# override what's here, so this is purely for local dev.
#
#   cp .env.example .env   # then fill in the blanks below
#
# Leave a value blank to keep the stub/default. Set INTEGRATIONS_MODE=live (or a
# per-service *_MODE=live) to exercise a real key.

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Global stub/live switch. Keep `stub` for the no-keys local loop.
INTEGRATIONS_MODE=stub

# Per-service overrides (optional). Flip just one service to `live` to test its
# key without turning everything on, e.g. PIONEER_MODE=live.
# GUILD_MODE=
# PIONEER_MODE=
# COMPOSIO_MODE=
# OPENAI_REALTIME_MODE=

# ── Database ────────────────────────────────────────────────────────────────
# Leave DATABASE_URL blank to use local in-process PGlite. Set it to your
# managed Postgres connection string to use that instead (add ?sslmode=require
# if your provider needs TLS).
# DATABASE_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# BETTER_AUTH_URL=http://localhost:3000

# ── LLM gateway: Pioneer (replaces TrueFoundry) ─────────────────────────────
# OpenAI-compatible; auth is the X-API-Key header (handled in code).
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai/v1
# Use a tool-calling-capable passthrough model for the agent loop.
TEXT_MODEL=gpt-4.1

# ── Voice interview: OpenAI Realtime ────────────────────────────────────────
OPENAI_API_KEY=
VOICE_MODEL=gpt-realtime-2

# ── Connectors: Composio (replaces Airbyte) ─────────────────────────────────
# Per-end-user Notion/GitHub/Slack connected accounts.
COMPOSIO_API_KEY=

# ── Analytics: ClickHouse (CDC target + agent SQL tool) ─────────────────────
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# ── Governance: Guild AI (run tracing / approval gates) ─────────────────────
# GUILD_API_KEY=
# GUILD_WORKSPACE_ID=
